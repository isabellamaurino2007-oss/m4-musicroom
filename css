body {
    background-color: #5a0011; /* Color rojo oscuro del diseño */
    color: white;
    font-family: sans-serif;
    padding: 20px;
}

h1 {
    margin-bottom: 20px;
}

.album-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* Crea 4 columnas iguales */
    gap: 20px;
}

.card {
    text-align: center;
}

.card img {
    width: 200px;      /* Ancho fijo para todas */
    height: 200px;     /* Alto fijo para todas */
    object-fit: cover; /* Recorta la imagen para que encaje perfecto */
    border-radius: 8px;
    display: block;
    margin: 0 auto;    /* Centra la imagen en su espacio */
}

.card p {
    margin-top: 10px;
    font-size: 14px;
}